# AWS credentials and region (used when provider is "aws")
# Copy to .env and fill in. Never commit .env.
#
# On Windows: same format (no "set" prefix). The app loads .env automatically.
# To create .env from this file:  powershell -File scripts\set_aws_env.ps1 -CreateEnv
#
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_DEFAULT_REGION=us-east-1
